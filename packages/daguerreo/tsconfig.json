{
    "compilerOptions": {
        "noEmit": false,
        "moduleResolution": "Bundler",
        "target": "esnext",
        "module": "esnext",
        "outDir": "dist",

        "verbatimModuleSyntax": true,
        "lib": ["DOM", "ESNext"],

        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "declaration": true,
        "strict": true,

        "types": ["vite/client"],
        "rootDir": "."
    },
    "files": ["lib/index.ts"],
    "include": ["lib/**/*.ts", "../../global.d.ts"],
    "exclude": ["dist"]
}
